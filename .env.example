# OpenAI API key for GPT-4o chart analysis.
OPENAI_API_KEY=

# Angel One broker credentials
ANGELONE_API_KEY=your_smartapi_key
ANGELONE_CLIENT_CODE=your_client_code
ANGELONE_PASSWORD=your_password
# Paste your Angel One TOTP secret key here (the base32 string from your authenticator setup).
# When set, the app auto-generates the 6-digit TOTP so you don't need to type it manually.
ANGELONE_TOTP_SECRET=

# preview is the safe default. Change to live only after you verify the flow.
ANGELONE_DEFAULT_MODE=preview

# Common intraday defaults for ATM option selling.
ANGELONE_PRODUCT_TYPE=INTRADAY
ANGELONE_ORDER_TYPE=MARKET
ANGELONE_ORDER_VARIETY=NORMAL
ANGELONE_ORDER_DURATION=DAY

# Quantity controls
ANGELONE_LOTS=1
ANGELONE_STRIKE_STEP=50
ANGELONE_MIN_CONFIDENCE=60
ANGELONE_SYMBOL_NAME=NIFTY

# Live quote source used before placing live ATM option orders.
ANGELONE_SPOT_EXCHANGE=NSE
ANGELONE_SPOT_TRADING_SYMBOL=Nifty 50
ANGELONE_SPOT_SYMBOL_TOKEN=99926000

# Telegram notifications (optional)
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your chat ID or group ID (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=
# Send notification on AI signal generation (true/false)
TELEGRAM_NOTIFY_SIGNAL=true
# Send notification on live order placement (true/false)
TELEGRAM_NOTIFY_ORDER=true
